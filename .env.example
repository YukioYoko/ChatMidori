# Copia este archivo a ".env" y llena tus valores reales.
# NUNCA subas tu archivo ".env" real a git (ya está en .gitignore).

# --- Anthropic (Claude) ---
# Consíguela en https://console.anthropic.com -> API Keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Twilio (WhatsApp) ---
# Consíguelos en el Console de Twilio (Account SID y Auth Token)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=tu_auth_token_de_twilio
# Sandbox por default; en producción será tu número de WhatsApp Business real.
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# --- Seguridad (opcional pero recomendado en producción) ---
VALIDATE_TWILIO_SIGNATURE=false

# --- Recordatorios automáticos del día anterior ---
# Content SID de la plantilla de WhatsApp aprobada por Meta (ver
# instrucciones en whatsapp_client.py). Sin esto, los recordatorios no
# se envían (se loguea una advertencia clara).
TWILIO_REMINDER_CONTENT_SID=

# Hora del día (0-23, hora de México) en que se disparan los recordatorios.
REMINDER_HOUR=10

# Pon "false" si tu hosting se duerme (ej. Render Free) y prefieres
# disparar los recordatorios con un cron externo en vez del scheduler
# interno. Ver la sección de recordatorios en main.py.
REMINDER_SCHEDULER_ENABLED=true

# Secreto para proteger el endpoint POST /tasks/send-reminders si usas
# un cron externo. Genera algo aleatorio, ej. con: openssl rand -hex 16
REMINDER_SECRET=

# --- Lista negra y depósitos de confirmación ---
# Secreto para los endpoints /admin/blacklist. Genera algo aleatorio.
ADMIN_SECRET=

# Números en lista negra "semilla" (separados por coma). Útil en hosting
# con disco efímero donde blacklist.json se borra en cada redeploy.
BLACKLIST_NUMBERS=
